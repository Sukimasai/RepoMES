generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventStatus { UPCOMING, ONGOING, FINISHED }
enum BoothStatus { CONFIRMED, TBA }
enum POStatus { UPCOMING, ACTIVE, CLOSED }

model Event {
  id          String        @id @default(uuid())
  name        String
  location    String
  city        String
  country     String
  startDate   DateTime
  endDate     DateTime
  status      EventStatus   @default(UPCOMING)
  
  vendorEvents VendorEvent[]
  preOrders    PreOrder[]
  createdAt    DateTime      @default(now())
}

model Vendor {
  id          String        @id @default(uuid())
  name        String
  description String?
  
  vendorEvents VendorEvent[]
  merchandises Merchandise[]
  preOrders    PreOrder[]
  createdAt    DateTime      @default(now())
}

model VendorEvent {
  id          String      @id @default(uuid())
  vendorId    String
  eventId     String
  boothNumber String?
  boothStatus BoothStatus @default(TBA)
  poAvailable Boolean     @default(false)
  poLink      String?

  vendor      Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([vendorId, eventId])
}

model Merchandise {
  id          String   @id @default(uuid())
  vendorId    String
  name        String
  salesStatus String   @default("PO_OTS")
  
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  fandoms     Fandom[] 
}

model Fandom {
  id          String        @id @default(uuid())
  name        String        @unique
  merchandises Merchandise[] 
}

model PreOrder {
  id          String   @id @default(uuid())
  vendorId    String
  eventId     String
  startDate   DateTime
  endDate     DateTime
  poUrl       String
  status      POStatus @default(UPCOMING)

  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}